# Ignore Visual Studio specific files
.vs/
*.vcxproj.user
*.VC.db
*.VC.VC.opendb
*.opendb
*.suo
*.user
*.userosscache
*.sln.docstates

# Build folders (local only)
Debug/
Release/
x64/
x86/
bin/
obj/
[Bb]uild/

# Intermediate/build artifacts
*.obj
*.pdb
*.ipdb
*.iobj
*.ilk
*.idb
*.tlog
*.lastbuildstate
*.log

# Runtime binaries
*.exe
*.dll
*.lib
*.exp

# IDE/editor
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp

# SFML local dependencies
/include/SFML/
/lib/*sfml*
/bin/*sfml*.dll
/vcpkg_installed/

# Local database/testing files
*.db
*.sqlite
local_data.txt
